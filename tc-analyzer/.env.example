# ── Copy to .env  —  fill in ONE provider ─────────────────────────────────────

# ✅ RECOMMENDED: Groq (completely free, no CC needed)
# Sign up at https://console.groq.com → API Keys → Create key
GROQ_API_KEY=gsk_your_key_here

# ── OR: Google Gemini (free tier: 15 req/min, 1500 req/day)
# Get key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza_your_key_here

# ── OR: OpenAI (paid, ~$0.003 per analysis with gpt-4o-mini)
# OPENAI_API_KEY=sk-your_key_here

# ── OR: Ollama (100% local, run: ollama pull llama3.2 && ollama serve)
# No key needed — just start ollama locally

# ── Optional overrides ────────────────────────────────────────────────────────
# TC_LLM_PROVIDER=groq
# TC_EMBED_PROVIDER=huggingface
# TC_MODEL=llama-3.3-70b-versatile
